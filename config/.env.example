# ============================================================
# Avatar Video Pipeline - 環境設定
# ============================================================
# このファイルをコピーして .env にリネームしてください
# copy .env.example .env

# --- GPU設定 ---
CUDA_VISIBLE_DEVICES=0
# VRAM制限 (MB) - RTX 4090: 24576, RTX 4500: 24576
GPU_VRAM_LIMIT=24576

# --- ComfyUI設定 ---
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_PATH=C:\ComfyUI
# xformersを有効化 (推奨)
COMFYUI_ENABLE_XFORMERS=true

# --- Blender設定 ---
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 4.2\blender.exe
# レンダリングエンジン: EEVEE / CYCLES
BLENDER_RENDER_ENGINE=EEVEE
# 出力解像度
RENDER_WIDTH=1024
RENDER_HEIGHT=1024

# --- AI モデルパス ---
# FLUX.1 [dev]
FLUX_MODEL_PATH=models/flux1-dev.safetensors
# ControlNet
CONTROLNET_CANNY_PATH=models/controlnet-canny.safetensors
CONTROLNET_DEPTH_PATH=models/controlnet-depth.safetensors
# Wan 2.1 I2V
WAN21_MODEL_PATH=models/wan21-i2v.safetensors
# LivePortrait
LIVEPORTRAIT_MODEL_PATH=models/liveportrait/

# --- TTS設定 ---
# エンジン: style_bert_vits2 / openai
TTS_ENGINE=style_bert_vits2
# StyleBERT-VITS2
STYLE_BERT_VITS2_PATH=C:\StyleBERT-VITS2
STYLE_BERT_VITS2_MODEL=jvnv-F1-jp
# OpenAI (フォールバック)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_TTS_VOICE=nova

# --- FFmpeg設定 ---
FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# ハードウェアエンコード (NVENC)
FFMPEG_HWACCEL=cuda
FFMPEG_ENCODER=h264_nvenc
# 出力品質 (CRF相当: 0-51, 低いほど高品質)
FFMPEG_QUALITY=18

# --- APIサーバー設定 ---
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change-me-to-a-secure-random-string
# gpurental.jpとの連携
GPURENTAL_API_URL=https://gpurental.jp/api
GPURENTAL_API_KEY=your-api-key-here

# --- ジョブ設定 ---
# 最大同時実行ジョブ数
MAX_CONCURRENT_JOBS=1
# ジョブタイムアウト (秒)
JOB_TIMEOUT=3600
# 出力ディレクトリ
OUTPUT_DIR=output
# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
