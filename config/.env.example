# ============================================================
# cocoro-influencer 環境設定 (cocoro-render-01専用)
# ============================================================
# このファイルをコピーして .env にリネームしてください
#   cp config/.env.example config/.env
#
# サーバー: cocoro-render-01 (192.168.50.48)
# GPU: RTX PRO 6000 Blackwell 96GB / RAM: 256GB

# ============================================================
# APIキー
# ============================================================

# --- Kling AI API ---
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# --- Ollama LLM ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Style-Bert-VITS2 (TTS) ---
STYLE_BERT_VITS2_URL=http://localhost:5000
# SPEAKER_ID=0

# --- APIサーバー ---
APP_HOST=0.0.0.0
APP_PORT=8082
LOG_LEVEL=INFO

# ============================================================
# モデル・パス設定 (cocoro-render-01 固定)
# ============================================================

# Wav2Lip
WAV2LIP_PYTHON=/data/models/Wav2Lip/venv/bin/python
WAV2LIP_DIR=/data/models/Wav2Lip

# Wan2.1 ローカル動画生成 (RTX PRO 6000 Blackwell 96GB)
WAN2_PYTHON=/data/venv/wan2/bin/python
WAN2_MODEL_PATH=/data/models/Wan2.1/I2V-14B-480P

# InstantID
INSTANTID_PYTHON=/data/models/InstantID/venv/bin/python
INSTANTID_DIR=/data/models/InstantID

# ============================================================
# GPU・出力設定
# ============================================================
CUDA_VISIBLE_DEVICES=0
OUTPUT_DIR=/data/outputs
MAX_CONCURRENT_JOBS=1
JOB_TIMEOUT=7200
