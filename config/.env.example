# ============================================================
# cocoro-influencer 環境設定
# ============================================================
# このファイルをコピーして .env にリネームしてください
#   cp config/.env.example config/.env

# ============================================================
# サーバー共通設定
# ============================================================

# --- Kling AI API ---
KLING_ACCESS_KEY=your-kling-access-key
KLING_SECRET_KEY=your-kling-secret-key

# --- Ollama LLM ---
# cocoro-server-01: localhost, cocoro-render-01: 192.168.50.77
OLLAMA_BASE_URL=http://localhost:11434

# --- Style-Bert-VITS2 (TTS) ---
STYLE_BERT_VITS2_URL=http://localhost:5000
# SPEAKER_ID=0

# --- APIサーバー ---
APP_HOST=0.0.0.0
# cocoro-server-01: 8082, cocoro-render-01: 8083
APP_PORT=8082
LOG_LEVEL=INFO

# ============================================================
# サーバー別設定: Wav2Lip パス
#   cocoro-server-01 → /mnt/models/Wav2Lip/venv/bin/python
#   cocoro-render-01 → /opt/wav2lip-venv/bin/python
# ============================================================
WAV2LIP_PYTHON=/mnt/models/Wav2Lip/venv/bin/python
WAV2LIP_DIR=/mnt/models/Wav2Lip

# cocoro-render-01 では以下にコメントを切り替え:
# WAV2LIP_PYTHON=/opt/wav2lip-venv/bin/python
# WAV2LIP_DIR=/opt/wav2lip

# ============================================================
# サーバー別設定: Wan2.1 ローカル動画生成
#   cocoro-render-01 (RTX PRO 6000 Blackwell 96GB) に配備
#   cocoro-server-01 ではKling AIにフォールバック
# ============================================================
WAN2_PYTHON=/data/venv/wan2/bin/python
WAN2_MODEL_PATH=/data/models/Wan2.1/I2V-14B-480P

# ============================================================
# GPU・出力設定
# ============================================================
CUDA_VISIBLE_DEVICES=0
OUTPUT_DIR=/mnt/data/outputs
MAX_CONCURRENT_JOBS=1
JOB_TIMEOUT=7200
